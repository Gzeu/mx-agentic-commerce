# MultiversX Network
MULTIVERSX_NETWORK=mainnet
# mainnet | devnet | testnet

# Smart Contract Addresses (deploy first, then fill)
AGENT_REGISTRY_ADDRESS=erd1qqqqqqqqqqqqqpgq...
COMMERCE_ENGINE_ADDRESS=erd1qqqqqqqqqqqqqpgq...
REPUTATION_NFT_ADDRESS=erd1qqqqqqqqqqqqqpgq...

# MCP Server
MCP_SERVER_PORT=3001
MCP_API_KEY=your-mcp-api-key-here

# Frontend (Next.js)
NEXT_PUBLIC_MULTIVERSX_NETWORK=mainnet
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=erd1qqqqqqqqqqqqqpgq...
NEXT_PUBLIC_COMMERCE_ENGINE_ADDRESS=erd1qqqqqqqqqqqqqpgq...
NEXT_PUBLIC_REPUTATION_NFT_ADDRESS=erd1qqqqqqqqqqqqqpgq...
NEXT_PUBLIC_MCP_SERVER_URL=http://localhost:3001

# xPortal / MultiversX DApp
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
NEXT_PUBLIC_XPORTAL_NATIVE_AUTH_ORIGIN=http://localhost:3000

# x402 Payment Configuration
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_NETWORK=base-mainnet

# AP2 / Agent Authorization
AP2_MANDATE_TTL_SECONDS=300
AP2_MAX_AMOUNT_EGLD=10

# LLM / AI Provider (for agent reasoning)
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
LLM_MODEL=openai/gpt-4o

# UCP Discovery
UCP_REGISTRY_URL=https://ucp.google.com/registry
UCP_API_KEY=your-ucp-api-key

# ACP / Stripe
STRIPE_API_KEY=sk_live_...
ACP_CHECKOUT_URL=https://acp.openai.com/checkout

# Deployment
DEPLOY_WALLET_PEM_PATH=./wallet.pem
DEPLOY_NETWORK=devnet
